# Supabase — public (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — deploy-hook uses the service role to bypass RLS. NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared secret the CI deploy-hook must send in the x-deploy-secret header.
DEPLOY_HOOK_SECRET=some-long-random-string

# Optional: forward archive results to Discord (leave empty to disable).
DISCORD_WEBHOOK_URL=
