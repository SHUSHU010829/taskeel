# ============================================================
# taskeel — environment variables (copy to .env.local)
# ============================================================
# Supabase migrated to a new API key format:
#   Publishable key  sb_publishable_...  → replaces the old anon key
#   Secret key       sb_secret_...       → replaces the old service_role key
# Both work with supabase-js. Grab them from:
#   Supabase Dashboard → Settings → API Keys (Publishable and secret API keys)
# The Project URL is in the top-right "Connect" button, or Settings → General.
# The variable names below are unchanged — just paste the new key VALUES in.

# --- public (safe in the browser; RLS protects the data) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# paste the Publishable key (sb_publishable_...) here
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# --- server only — NEVER prefix with NEXT_PUBLIC_ ---
# paste the Secret key (sb_secret_...) here. Click "Create new secret key" —
# it is shown only once on creation, so copy it immediately. Bypasses RLS;
# used by the deploy-hook route.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# Shared secret the CI deploy-hook must send in the x-deploy-secret header.
DEPLOY_HOOK_SECRET=some-long-random-string

# Optional: forward archive results to Discord (leave empty to disable).
DISCORD_WEBHOOK_URL=
